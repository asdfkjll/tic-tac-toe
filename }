const gameboard = (() => {
    let gameboard = [
	["", "", ""],
	["", "", ""],
	["", "", ""]
    ] 

    const reset = () => {
	gameboard = [
	    ["", "", ""],
	    ["", "", ""],
	    ["", "", ""]
	] 
    } 

    const getGameboard = () => gameboard

    const getRow = (rowIndex) => gameboard[rowIndex] 

    const getCol = (colIndex) => {
	const col = []
	for(const i in gameboard) col.push(gameboard[i][colIndex]) 
	return col
    }

    const getDiagonal = (reverse = false) => {
	const diagonal = []

	if(reverse !== false) {
	    gameboard.reverse()
	    const reversedDiagonal = getDiagonal()
	    gameboard.reverse()

	    return reversedDiagonal 
	}

	for(const i in gameboard) diagonal.push(gameboard[i][i]) 

	return diagonal
    }

    const getFreeSpaces = () => {
	let freeSpaces = 0
 
	gameboard.forEach((row) => {
	    for(const elem of row) {
		if(elem === "") freeSpaces++ 
	    }
	})
	
	return freeSpaces
    }

    const getWinner = () => {
	// reads the entire gameboard and returns a winner, if tie returns "tie", otherwise returns null

	for(const i in getGameboard()) {
	    const winnerRow = arrayWinner(getRow(i))
	    const winnerCol = arrayWinner(getCol(i))

	    if(!(winnerRow === null && winnerCol === null)) {
		return winnerRow === null ? winnerCol : winnerRow
	    }
	}

	const winnerDiag = arrayWinner(getDiagonal())
	const winnerReversedDiag = arrayWinner(getDiagonal(true))

	if(!(winnerDiag === null && winnerReversedDiag === null)) {
	    return winnerDiag === null ? winnerReversedDiag : winnerDiag
	} 

	if(getFreeSpaces() === 0) {
	    return "tie"
	}

	return null
    }

    const arrayWinner = (array) => {
	// Iterate an array to determine an winner (ej: ["x", "x", "x"] returns "x")
	// returns the winner object, if there is no winner then returns null

	const firstElem = array[0]

	if(firstElem === "") return null
	for(const elem of array) if(elem !== firstElem) return null

	return firstElem
    }

    return {
	getGameboard,
	reset,
	getRow,
	getCol,
	getDiagonal,
	getFreeSpaces,
	getWinner
    }
})()

function player(name, mark) {
    let score = 0
    
    const getName = () => name
    const getMark = () => mark
    const getScore = () => score
    const giveScore = () => score++  
    const placeMark = (position, gameboard) => {
	// position: {x, y} , gameboard: gameboard object instance where the mark is going to be placed
	// place a mark in the gameboard array at the specified position, returns an object with the move info, if cannot place the mark then returns null 

	// error checkers
	// * missing data	
	if(!position || !gameboard || typeof position.x !== "number" || typeof position.y !== "number") {
	    console.warn(`placeMark(): missing arguments or invalid data type`)
	    return null
	}

	const board = gameboard.getGameboard()

	// * index overflow
	if(position.y < 0 || position.y >= board.length || position.x < 0 || position.x >= board[0].length) {
	    console.warn(`placeMark(): invalid index, tried x: ${position.x}/${board[0].length}, y: ${position.y}/${board.length}`)
	    return null
	}

	// * occupied space
	if(board[position.y][position.x] !== "") { 
	    console.warn(`placeMark(): invalid move at position x: ${position.x}, y: ${position.y} its been already taken`)
	    return null
	} 

	board[position.y][position.x] = mark

	return { 
	    x: position.x, 
	    y: position.y, 
	    name, 
	    mark 
	} 
    }

    return { 
	getName,
	getMark,
	getScore,
	giveScore,
	placeMark 
    }
} 

const ui = (() => {
    const renderGameboard = (gameboard) => {
	// gameboard must be an array
    
	if(!gameboard) {
	    console.warn(`warning: renderGamboard function call is missing "gameboard" arguments`)
	    return null
	}

	for(const y in gameboard) {
	    for(const x in gameboard[y]) {
		const space = document.querySelector(`[data-x="${x}"][data-y="${y}"]`)
		space.textContent = gameboard[y][x]
	    }
	}	
    }

    const renderPlayerInfo = (playerOne, playerTwo) => {
	const playerOneElement = document.querySelector(".info-p1")
	const playerTwoElement= document.querySelector(".info-p2")

	playerOneElement.textContent = `${playerOne.getName()}:${playerOne.getScore()}`
	playerTwoElement.textContent = `${playerTwo.getName()}:${playerTwo.getScore()}`
    }

    const gameOptionsMenuController = (start, reset) => {
	const dialog = document.querySelector("#game-options")
	const showButton = document.querySelector("#game-options-open-btn")
	const closeButton = document.querySelector("#game-options button")
	const gameForm = document.querySelector("#game-options form")
	const resetBtn = document.querySelector("#game-options #reset-btn")

	// "Show the dialog" button opens the dialog modally
	showButton.addEventListener("click", () => dialog.showModal())

	// "Close" button closes the dialog
	closeButton.addEventListener("click", () => dialog.close())

	// Controls the form inside the dialog
	gameForm.addEventListener("submit", (e) => {
	    e.preventDefault()
	    
	    const playerOneName = document.querySelector("#playerOne-name").value
	    const playerTwoName = document.querySelector("#playerTwo-name").value

	    start(playerOneName, playerTwoName)
	    dialog.close()
	})
	
	resetBtn.addEventListener("click", () => {
	    reset(game.players["x"].name, game.players["o"].name)
	    dialog.close()
	})
    }

    const getSpaceClicked = (abortSignal) => {
	const board = document.querySelector(".board")

	return new Promise((resolve, reject) => {
	    if(abortSignal?.aborted) {
		return reject(new Error("Game Over"))
	    }

	    board.addEventListener("click", function onClick(event) {
		const targetSpace = event.target

		if (targetSpace && targetSpace.dataset.x !== undefined) {
		    board.removeEventListener("click", onClick)
		    resolve(targetSpace) 
		}
	    }, { signal: abortSignal })

	    abortSignal?.addEventListener("abort", () => {
		reject(new Error("Game Over"))
	    })
	})
    }

    return { 
	renderGameboard, 
	renderPlayerInfo, 
	getSpaceClicked,
	gameOptionsMenuController
    }
})()

const game = (() => {
    // controls the main logic and game bucle
    let gameController = new AbortController()
    let gameOver = true
    let players

    const stop = () => { 
	console.log("Stop Game...")

	gameOver = true 
	if(gameController) gameController.abort() 
    }

    const start = async(playerOneName = "gugu gaga", playerTwoName = "chikiro-chan") => {
	console.log("New Game Started")

	gameOver = false
	gameController = new AbortController()
	players = {"x": player(playerOneName, "x"), "o": player(playerTwoName, "o")}

	let turn = players["x"]

	ui.renderGameboard(gameboard.getGameboard())
	ui.renderPlayerInfo(players["x"], players["o"])

	while(!gameOver) {
	    try {
		console.log(`plays "${turn.getName()}" as "${turn.getMark()}"`)

		let winner
		let spaceSelected
		let playerMove
		let cordinates

		// reads player's move and play it if valid
		do {
		    spaceSelected = undefined
		    spaceSelected = await ui.getSpaceClicked(gameController.signal)
		    cordinates = {x: Number(spaceSelected.dataset.x), y: Number(spaceSelected.dataset.y)}
		    playerMove = turn.placeMark(cordinates, gameboard)
		} while(spaceSelected === undefined || playerMove === null)

		ui.renderGameboard(gameboard.getGameboard())

		// determine if there is a winner/tie in the gameboard after the move, 	
		winner = gameboard.getWinner()

		if(winner === "tie") {
		    console.log("GAME OVER! its a tie")

		    gameOver = true
		} else if(winner !== null) {
		    console.log(`GAME OVER! The winner is "${players[winner].getName()}" playing as "${players[winner].getMark()}"`)

		    players[winner].giveScore()
		    gameOver = true
		} 

		ui.renderPlayerInfo(players["x"], players["o"])

		// flip turn to the other player
		turn = turn == players["x"] ? players["o"] : players["x"] 
	    } catch(error) {
		break
	    }
	}
    }

    return { 
	start, 
	stop
    }
})()

function tttInit(playerOneName, playerTwoName) {
    gameboard.reset()
    game.stop()
    game.start(playerOneName, playerTwoName)
}

function tttRestart() {
    
}

ui.gameOptionsMenuController(tttInit, tttRestart)

